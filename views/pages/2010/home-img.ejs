<!DOCTYPE html>
<html>
  <head>
    <title>Google Images</title>
    <link rel="stylesheet" href="/static/assets/css/2010/home.css" />
    <link rel="shortcut icon" href="/static/assets/images/2010/favicon.ico" type="image/x-icon" />
    <script src="/static/assets/js/2010/gbar.js"></script>
  </head>
  <body bgcolor="#ffffff" text="#000000" link="#0000cc" vlink="#551a8b" alink="#ff0000">
    <div id="ghead">
      <div id="gog">
        <div id="gbar">
          <nobr>
            <a href="/" class="gb1">Web</a>
            <b class="gb1">Images</b>
            <a href="https://www.google.com/videohp" class="gb1">Videos</a>
            <a href="https://maps.google.com/maps" class="gb1">Maps</a>
            <a href="https://news.google.com/home" class="gb1">News</a>
            <a href="https://www.google.com/shopping" class="gb1">Shopping</a>
            <a href="https://mail.google.com/mail/" class="gb1">Gmail</a>
            <a
              href="https://about.google/products/"
              onclick="
                this.blur();
                gbar.tg(event, 'gbi');
                return !1;
              "
              aria-haspopup="true"
              class="gb3"
            >
              <u>more</u> <small>▼</small>
            </a>
            <div class="gbm" id="gbi" style="left: 341px; right: auto; top: 24px; visibility: hidden">
              <a href="https://books.google.com/bkshp" class="gb2">Books</a>
              <a href="https://www.google.com/finance" class="gb2">Finance</a>
              <a href="https://translate.google.com/" class="gb2">Translate</a>
              <a href="https://scholar.google.com/" class="gb2">Scholar</a>
              <a href="https://blogsearch.google.com/" class="gb2">Blogs</a>
              <div class="gb2">
                <div class="gbd"></div>
              </div>
              <a href="https://www.youtube.com/" class="gb2">YouTube</a>
              <a href="https://calendar.google.com/" class="gb2">Calendar</a>
              <a href="https://photos.google.com/" class="gb2">Photos</a>
              <a href="https://docs.google.com/" class="gb2">Documents</a>
              <a href="https://www.google.com/reader/about/" class="gb2">Reader</a>
              <a href="https://sites.google.com/" class="gb2">Sites</a>
              <a href="https://groups.google.com/" class="gb2">Groups</a>
              <div class="gb2">
                <div class="gbd"></div>
              </div>
              <a href="https://about.google/products/" class="gb2">even more »</a>
            </div>
          </nobr>
        </div>
        <% if (cookies.email) { %>
          <div id="guser" width="100%">
            <nobr>
              <b><%= cookies.email %></b> |
              <span id="gbe"><a href="/ig" class="gb4">iGoogle</a> | </span>
              <a
                href="https://about.google/products/"
                onclick="
                  this.blur();
                  gbar.tg(event, 'gbu');
                  return !1;
                "
                aria-haspopup="true"
                class="gb3"
              >
                <u>Settings</u> <small>▼</small>
              </a> |
              <div class="gbm" id="gbu" style="right: 63px; left: auto; top: 24px; visibility: hidden">
                <a href="/preferences" class="gb2">Search settings</a>
                <a href="/accounts/manage" class="gb2">Google Account settings</a>
              </div>
              <a href="/accounts/logout" class="gb4">Sign out</a>
            </nobr>
          </div>
        <% } else { %>
          <div id="guser" width="100%">
            <nobr>
              <span id="gbn" class="gbi"></span>
              <span id="gbf" class="gbf"></span>
              <span id="gbe"><a href="/ig" class="gb4">iGoogle</a> | </span>
              <a href="/preferences" class="gb4">Search settings</a> |
              <a href="/accounts/login" class="gb4">Sign in</a>
            </nobr>
          </div>
        <% } %>
        <div class="gbh" style="left: 0"></div>
        <div class="gbh" style="right: 0"></div>
      </div>
    </div>
    <center>
      <br clear="all" id="lgpd" />
      <div id="lga"><img alt="Google" height="110" src="/static/assets/images/2010/images_logo_lg.gif" width="276" id="logo" style="padding: 28px 0 14px" /><br /><br /></div>
      <form action="/search" <%= preferences.results_tab == "true" ? "target=_blank" : "" %>>
        <table cellpadding="0" cellspacing="0">
          <tbody>
            <tr valign="top">
              <td width="25%">&nbsp;</td>
              <td align="center" nowrap="nowrap">
                <div class="ds" style="height: 32px; margin: 4px 0">
                  <input type="hidden" name="category" value="images">
                  <input
                    autocomplete="off"
                    maxlength="2048"
                    name="q"
                    class="lst"
                    title="Google Search"
                    size="57"
                    style="
                      background: #fff;
                      border: 1px solid #ccc;
                      border-bottom-color: #999;
                      border-right-color: #999;
                      color: #000;
                      font:
                        18px arial,
                        sans-serif bold;
                      height: 25px;
                      margin: 0;
                      padding: 5px 8px 0 6px;
                      vertical-align: top;
                    "
                  />
                </div>
                <span class="ds">
                  <span class="lsbb"><input type="submit" value="Search Images" class="lsb" />
                  </span>
                </span>
              </td>
              <td nowrap="nowrap" width="25%" align="left" valign="middle" class="sblc"><a href="/advanced_iamge_search">Advanced Image Search</a></td>
            </tr>
          </tbody>
        </table>
      </form>
      <div style="font-size: 83%; min-height: 3.5em"><br /></div>
      <div id="res"></div>
      <span id="footer">
        <center id="fctr">
          <div style="font-size: 10pt">
            <div id="fll" style="margin: 19px auto 19px auto; text-align: center">
              <a href="https://ads.google.com/">Advertising&nbsp;Programs</a><a href="https://business.google.com/">Business Solutions</a><a href="https://about.google/">About Google</a>
            </div>
          </div>
          <p style="color: #767676; font-size: 8pt">© <%= preferences.copyright %> - <a href="https://policies.google.com/privacy">Privacy</a></p>
        </center>
      </span>
    </center>
  </body>
</html>
